# --------------------------------------------------------------------------
# Orient Advertise — Frontend container env template.
#
# Copy to `.env` for `docker compose` / `make up`:
#   cp .env.docker.example .env
#
# These values are read by docker-compose.yml and injected into the running
# container at start (see docker/entrypoint.sh). They are NOT baked into the
# image — the same image is portable across environments.
#
# **TO POINT AT PROD**: change VITE_API_URL (and VITE_WS_URL) to the prod
# origin and run `make rebuild` (or `docker compose up -d --force-recreate`).
# That's the only change needed.
# --------------------------------------------------------------------------

# Optional — pins a stable compose project name.
COMPOSE_PROJECT_NAME=orient-advertise

# --- Docker Hub publishing ---
# Used by docker-compose.yml to build image names: <user>/orient-frontend:<tag>.
# Required only when running `make push` / `docker compose push`.
#   DOCKERHUB_USERNAME -> your Docker Hub user or org (e.g. `acme`)
#   IMAGE_TAG          -> tag to push (e.g. `1.0.0`, `latest`, a git SHA)
DOCKERHUB_USERNAME=developabror
IMAGE_TAG=dev

# --- Frontend runtime config ---
# Backend ORIGIN ONLY — no `/api`, no `/v1`, no trailing slash. The SPA's
# code uses absolute paths (`/api/devices`, `/auth/login`) under this origin.
# The SPA throws on boot if unset.
#
#   local backend:  http://localhost:8080
#   local mock-api: http://localhost:8090
#   production:     https://api.orient-advertise.example.com
VITE_API_URL=http://localhost:8080

# WebSocket URL — canonical shape (BE-19): ws(s)://<host>/ws — must
# end with /ws. The SPA validates this at boot and throws a clear
# error if the suffix is missing; trailing slash is stripped silently.
# Production uses wss://.
VITE_WS_URL=ws://localhost:8080/ws
