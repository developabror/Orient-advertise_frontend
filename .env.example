# Public Vite env vars (must be prefixed with VITE_ to be exposed to the client).
# Copy to .env.local for `npm run dev`.
#
# These are the SINGLE source of truth for backend URLs. Source code uses
# absolute paths (`/api/devices`, `/auth/login`), so VITE_API_URL must be the
# backend ORIGIN ONLY — no `/api`, no `/v1`, no trailing slash.
#
# To deploy to prod, change VITE_API_URL (and VITE_WS_URL) to the production
# origin. That's the only change needed.
#   prod example:  https://api.orient-advertise.example.com

# VITE_WS_URL canonical shape (BE-19): ws(s)://<host>/ws — must end
# with /ws. The SPA validates this at boot and throws a clear error
# if the suffix is missing; a trailing slash is stripped silently.
VITE_API_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080/ws
